# =============================================================================
# OceanGuard AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND — Vite (VITE_ prefix, bundled into the browser)
# -----------------------------------------------------------------------------

# Backend API URL  (local dev: http://localhost:8000)
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=false

# Cache / upload limits
VITE_CACHE_DURATION=300000
VITE_MAX_FILE_SIZE=104857600
VITE_MAX_VIDEO_DURATION=300

# Google Gemini AI — free key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (anon key — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# BACKEND — FastAPI / Python (no VITE_ prefix, never sent to browser)
# -----------------------------------------------------------------------------

# Supabase service key (keep secret — never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars_here

# CORS — comma-separated allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (used in verification email links)
FRONTEND_URL=http://localhost:5173

# Email — Gmail SMTP for verification emails
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords → create App Password
# 3. Paste the 16-char password below (spaces are fine)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your.gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=OceanGuard AI

# External data APIs (optional — synthetic fallback used if missing)
NOAA_CDO_TOKEN=your_noaa_token
WAQI_TOKEN=your_waqi_token

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# YOLO model
LOAD_YOLO_ON_STARTUP=true
WARMUP_YOLO_ON_LOAD=true
YOLO_WEIGHTS_PATH=./weights/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_INFER_SIZE=640

# Video processing
VIDEO_WORKERS=1
VIDEO_FRAME_SKIP=3
VIDEO_BATCH_SIZE=4
MAX_UPLOAD_SIZE=104857600
MAX_VIDEO_DURATION=300

# Admin bootstrap (change password before deploying!)
SEED_ADMIN_ON_STARTUP=true
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@oceanscan.ai
ADMIN_PASSWORD=change_this_before_production

# Logging
LOG_LEVEL=INFO
