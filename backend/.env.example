# Weather APIs (choose one or more)
OPENWEATHER_API_KEY=your_openweather_api_key_here
WEATHERAPI_KEY=your_weatherapi_key_here

# Marine Data APIs
COPERNICUS_USER=your_copernicus_username
COPERNICUS_PASS=your_copernicus_password

# Geographic APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Note: NOAA and EPA APIs don't require authentication
# The system will automatically use free fallback APIs if keys are not provided