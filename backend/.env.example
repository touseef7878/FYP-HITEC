# Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# ── Optional — real data fetching (synthetic fallback used if omitted) ────────

# NOAA Climate Data Online — https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_TOKEN=your_noaa_cdo_token

# World Air Quality Index — https://aqicn.org/api/
WAQI_TOKEN=your_waqi_token

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── File limits ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=104857600
MAX_VIDEO_DURATION=300

# ── Model ─────────────────────────────────────────────────────────────────────
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
