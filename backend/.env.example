# ── OceanScan AI Backend — Environment Variables Template ─────────────────────
# Copy this to .env and fill in your values.

# ── JWT (REQUIRED) ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your_jwt_secret_key_min_32_chars_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Frontend URL (for email verification links) ───────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Gmail SMTP — for user verification emails) ────────────────────────
# 1. Enable 2-Step Verification on Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create App Password → paste 16-char password below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your.gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=OceanGuard AI

# ── Database (Supabase only) ─────────────────────────────────────────────────
# Supabase is the only database backend.
SUPABASE_URL=https://zuophfoyuxlxumwcdvuz.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ── External Data APIs (optional — synthetic fallback used if absent) ─────────
NOAA_CDO_TOKEN=your_noaa_token
WAQI_TOKEN=your_waqi_token

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── File Limits ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=104857600
MAX_VIDEO_DURATION=300

# ── Model ─────────────────────────────────────────────────────────────────────
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
